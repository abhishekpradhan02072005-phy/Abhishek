clc;
clear;
clf;

//------------------------------------------------------
// Constants
//------------------------------------------------------
hc  = 1973;            // hbar*c (eV.Angstrom)
mc2 = 0.511e6;         // Electron rest energy (eV)

h2_2m = (hc^2)/(2*mc2);

//------------------------------------------------------
// Anharmonic Oscillator Parameters
//------------------------------------------------------
k = 100;      // eV/Angstrom^2
b = 30;       // eV/Angstrom^3

//------------------------------------------------------
// Radial Grid
//------------------------------------------------------
rmax = 8;
N = 5000;

h = rmax/(N+1);
r = (1:N)'*h;

//------------------------------------------------------
// Initial Conditions
//------------------------------------------------------
y0 = [0;1];

//------------------------------------------------------
// Schrödinger Equation
//------------------------------------------------------
function dy = sch(r,y)

    global E h2_2m k b

    // Anharmonic oscillator potential
    V = 0.5*k*r.^2 + (b/3)*r.^3;

    dy(1) = y(2);
    dy(2) = ((V-E)/h2_2m)*y(1);

endfunction

//------------------------------------------------------
// Boundary Function
//------------------------------------------------------
function f = boundary(Eguess)

    global E y0 r

    E = Eguess;

    y = ode(y0,r(1),r,sch);

    f = y(1,$);

endfunction

//------------------------------------------------------
// Find Ground State Energy
//------------------------------------------------------
Eg = fsolve(15,boundary);

disp("Ground State Energy = ");
disp(Eg);


//------------------------------------------------------
// Wavefunction
//------------------------------------------------------
E = Eg;

y = ode(y0,r(1),r,sch);

psi = y(1,:);

//------------------------------------------------------
// Potential
//------------------------------------------------------
V = 0.5*k*r.^2 + (b/3)*r.^3;

//------------------------------------------------------
// Plot
//------------------------------------------------------
clf();

plot(r,psi,"b","linewidth",3);
xtitle("Ground State Wavefunction");
xlabel("r (Angstrom)");
ylabel("u(r)");
xgrid();

figure();

plot(r,V,"r","linewidth",3);
xtitle("Anharmonic Oscillator Potential");
xlabel("r (Angstrom)");
ylabel("V(r) (eV)");
xgrid();
