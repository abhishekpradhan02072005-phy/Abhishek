clc;
clear;
clf;

//------------------------------------------------------
// Constants
//------------------------------------------------------
e2  = 14.402;          // eV.Angstrom
hc  = 1973;            // hbar*c (eV.Angstrom)
mc2 = 0.511e6;         // Electron rest energy (eV)

h2_2m = (hc^2)/(2*mc2);

//------------------------------------------------------
// Radial Grid
//------------------------------------------------------
rmax = 20;             // Angstrom
N    = 100000;

h = rmax/(N+1);
r = (1:N)'*h;

//------------------------------------------------------
// Initial Conditions
//------------------------------------------------------
y0 = [0;1];

//------------------------------------------------------
// Schrödinger Equation
//------------------------------------------------------
function dy = sch(r,y)

    global E h2_2m e2

    // Pure Coulomb Potential
    V = -e2./r;

    dy(1) = y(2);
    dy(2) = (V-E)/h2_2m * y(1);

endfunction

//------------------------------------------------------
// Boundary Function
//------------------------------------------------------
function f = boundary(Eguess)

    global E y0 r

    E = Eguess;

    y = ode(y0,r(1),r,sch);

    f = y(1,$);

endfunction

//------------------------------------------------------
// Find Ground-State Energy
//------------------------------------------------------
Eg = fsolve(-13.6,boundary);

disp("Ground State Energy (Hydrogen Atom) = ");
disp(Eg);

//------------------------------------------------------
// Wavefunction
//------------------------------------------------------
E = Eg;

y = ode(y0,r(1),r,sch);

plot(r,y(1,:),"b","linewidth",3);

xlabel("r (Angstrom)");
ylabel("u(r)");
title("Hydrogen Atom (Coulomb Potential)");
xgrid();
